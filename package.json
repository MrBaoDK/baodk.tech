{
  "name": "personal-site",
  "version": "1.0.0",
  "description": "Personal site",
  "scripts": {
    "dev": "pnpm --filter @mrbaodk/site start",
    "build": "pnpm --filter @mrbaodk/site build",
    "preview": "pnpm --filter @mrbaodk/site preview",
    "gh-deploy": "pnpm --filter @mrbaodk/site gh-deploy",
    "lint": "pnpm --filter @mrbaodk/site lint",
    "format": "pnpm --filter @mrbaodk/site format",
    "format:check": "pnpm --filter @mrbaodk/site format:check",
    "preinstall": "npx only-allow pnpm"
  },
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git@github:MrBaoDK/baodk.tech"
  },
  "author": "Bao DK",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MrBaoDK/baodk.tech/issues"
  }
}